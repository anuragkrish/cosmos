{
	"name": "<APPLICATION_NAME>",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@9.12.1",
	"scripts": {
		"dev": "concurrently \"panda --watch\" \"next dev --turbopack\" --names \"panda,next\" --prefix-colors \"blue,green\"",
		"build": "pnpm prepare:panda && NODE_OPTIONS=--max-old-space-size=4096 next build --turbopack",
		"start": "pnpm prepare:panda && NODE_OPTIONS=--max-old-space-size=4096 next start",
		"lint": "eslint",
		"prepare:husky": "husky",
		"prepare:panda": "panda codegen",
		"postinstall": "pnpm prepare:husky",
		"sdd:new": "tsx .sdd/commands/new_feature.ts",
		"sdd:plan": "tsx .sdd/commands/generate_plan.ts"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@headout/eevee": "7.0.4-etxt.1",
		"@headout/espeon": "2.94.0-canary.5",
		"@headout/onix": "4.3.1",
		"@headout/pixie": "2.3.0",
		"@remotion/bundler": "^4.0.481",
		"@remotion/fonts": "^4.0.481",
		"@remotion/google-fonts": "^4.0.481",
		"@remotion/player": "^4.0.481",
		"@remotion/renderer": "^4.0.481",
		"@tanstack/react-query": "^5.89.0",
		"@tanstack/react-table": "^8.21.3",
		"agentation": "^3.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"immer": "^10.1.3",
		"jszip": "^3.10.1",
		"lucide-react": "^1.21.0",
		"next": "16.2.9",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"remotion": "^4.0.481",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.8"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@pandacss/dev": "0.41.0",
		"@remotion/cli": "^4.0.481",
		"@tailwindcss/postcss": "^4.3.1",
		"@tanstack/eslint-plugin-query": "^5.89.0",
		"@tanstack/react-query-devtools": "^5.89.0",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"concurrently": "^9.2.1",
		"eslint": "^9",
		"eslint-config-next": "16.2.9",
		"gray-matter": "^4.0.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.6",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"tsx": "^4.19.2",
		"typescript": "^5"
	}
}
